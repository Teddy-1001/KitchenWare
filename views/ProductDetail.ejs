        <%- include("../partials/footer.ejs") %>

            <!-- =============== LIGHTBOX =============== -->
            <div class="fixed inset-0 bg-black/85 backdrop-blur-sm z-[1000] hidden place-items-center cursor-zoom-out anim-fade-in"
                id="lightbox">
                <button
                    class="absolute top-6 right-6 text-white/70 hover:text-white text-2xl transition z-10 bg-transparent border-none cursor-pointer"
                    id="closeLightbox">
                    <i class="fa-solid fa-xmark"></i>
                </button>
                <img id="lightboxImg" src="" alt="Zoomed product image"
                    class="max-w-[90vw] max-h-[85vh] object-contain rounded-2xl anim-scale-in">
            </div>

            <script>
                // ========== TAB SWITCHING ==========
                const tabBtns = document.querySelectorAll('.tab-btn');
                const tabContents = document.querySelectorAll('.tab-content');

                tabBtns.forEach(btn => {
                    btn.addEventListener('click', () => {
                        const tabId = btn.getAttribute('data-tab');
                        // Hide all tabs
                        tabContents.forEach(c => c.classList.add('hidden'));
                        // Show selected tab
                        const target = document.getElementById(tabId);
                        target.classList.remove('hidden');
                        // Remove active from all buttons
                        tabBtns.forEach(b => {
                            b.classList.remove('text-amber-700', 'border-b-[2.5px]', 'border-amber-500');
                            b.classList.add('text-zinc-400');
                        });
                        // Activate clicked button
                        btn.classList.remove('text-zinc-400');
                        btn.classList.add('text-amber-700', 'border-b-[2.5px]', 'border-amber-500');
                    });
                });
                // Activate first tab by default
                if (tabBtns.length) tabBtns[0].click();

                // ========== THUMBNAIL GALLERY ==========
                const mainImg = document.getElementById('mainImage');
                const thumbs = document.querySelectorAll('.thumb-img');
                mainImg.style.transition = 'opacity 0.25s ease';

                thumbs.forEach(thumb => {
                    thumb.addEventListener('click', () => {
                        mainImg.style.opacity = '0';
                        setTimeout(() => {
                            mainImg.src = thumb.getAttribute('data-img');
                            mainImg.style.opacity = '1';
                        }, 200);
                        thumbs.forEach(t => {
                            t.classList.remove('border-amber-500', 'shadow-lg', 'shadow-amber-200/50');
                            t.classList.add('border-transparent');
                        });
                        thumb.classList.remove('border-transparent');
                        thumb.classList.add('border-amber-500', 'shadow-lg', 'shadow-amber-200/50');
                    });
                });
                if (thumbs.length) {
                    thumbs[0].classList.remove('border-transparent');
                    thumbs[0].classList.add('border-amber-500', 'shadow-lg', 'shadow-amber-200/50');
                }

                // ========== LIGHTBOX ==========
                const lightbox = document.getElementById('lightbox');
                const lightboxImg = document.getElementById('lightboxImg');
                const mainWrap = document.getElementById('mainImageWrap');
                const closeLB = document.getElementById('closeLightbox');

                mainWrap.addEventListener('click', () => {
                    lightboxImg.src = mainImg.src;
                    lightbox.classList.remove('hidden');
                    lightbox.style.display = 'grid';
                    document.body.style.overflow = 'hidden';
                });
                function closeLightboxFn() {
                    lightbox.style.display = 'none';
                    lightbox.classList.add('hidden');
                    document.body.style.overflow = '';
                }
                lightbox.addEventListener('click', (e) => {
                    if (e.target === lightbox || e.target === closeLB || closeLB.contains(e.target)) closeLightboxFn();
                });
                document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightboxFn(); });

                // ========== OPTION PILLS ==========
                document.querySelectorAll('.option-pill').forEach(opt => {
                    opt.addEventListener('click', function () {
                        const siblings = this.parentElement.querySelectorAll('button');
                        siblings.forEach(s => {
                            s.classList.remove('bg-gradient-to-r', 'from-amber-500', 'to-amber-600', 'text-white', 'border-transparent', 'shadow-lg', 'shadow-amber-200/40', '-translate-y-px');
                            s.classList.add('border-zinc-200', 'text-zinc-600', 'bg-transparent');
                        });
                        this.classList.remove('border-zinc-200', 'text-zinc-600', 'bg-transparent');
                        this.classList.add('bg-gradient-to-r', 'from-amber-500', 'to-amber-600', 'text-white', 'border-transparent', 'shadow-lg', 'shadow-amber-200/40', '-translate-y-px');
                    });
                });

                // ========== QUANTITY ==========
                const qtyInput = document.getElementById('quantity');
                const cartQtyInput = document.getElementById('cartQtyInput');
                const buyNowQtyInput = document.getElementById('buyNowQtyInput');
                const maxStock = <%= utensil.stock %> || 99;

                function syncQty() {
                    const val = qtyInput.value;
                    if (cartQtyInput) cartQtyInput.value = val;
                    if (buyNowQtyInput) buyNowQtyInput.value = val;
                }

                document.querySelector('.qty-decr')?.addEventListener('click', () => {
                    let v = parseInt(qtyInput.value);
                    if (v > 1) {
                        qtyInput.value = v - 1;
                        syncQty();
                    }
                });
                document.querySelector('.qty-incr')?.addEventListener('click', () => {
                    let v = parseInt(qtyInput.value);
                    if (v < maxStock) {
                        qtyInput.value = v + 1;
                        syncQty();
                    }
                });

                // ========== WISHLIST TOGGLE ==========
                const wishBtn = document.getElementById('wishlistBtn');
                wishBtn?.addEventListener('click', () => {
                    const icon = wishBtn.querySelector('i');
                    const isActive = icon.classList.contains('fa-solid');
                    if (isActive) {
                        icon.classList.replace('fa-solid', 'fa-regular');
                        wishBtn.classList.remove('border-red-400', 'text-red-500', 'bg-red-50');
                        wishBtn.classList.add('border-zinc-200', 'text-zinc-400', 'bg-white');
                    } else {
                        icon.classList.replace('fa-regular', 'fa-solid');
                        wishBtn.classList.remove('border-zinc-200', 'text-zinc-400', 'bg-white');
                        wishBtn.classList.add('border-red-400', 'text-red-500', 'bg-red-50');
                    }
                });
            </script>

            

</body>

</html>