<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700&display=swap"
        rel="stylesheet">

    <title>KitchenWare | Your Cart</title>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        h1,
        h2,
        h3,
        h4 {
            font-family: 'Outfit', sans-serif;
        }

        .cart-item-card:hover {
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }
    </style>
</head>

<body class="bg-zinc-50 antialiased">

    <%- include("../partials/header.ejs") %>

        <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

            <!-- Page Header -->
            <div class="mb-12">
                <h1 class="text-4xl font-bold text-zinc-900 tracking-tight">Your Shopping Cart</h1>
                <p class="text-zinc-500 mt-2 font-light">Review your premium kitchen essentials before checkout.</p>
            </div>

            <div class="flex flex-col lg:flex-row gap-8">

                <!-- CART ITEMS SECTION -->
                <div class="lg:w-2/3">

                    <% if (cart.length===0) { %>
                        <!-- Empty State -->
                        <div class="bg-white border border-zinc-200 rounded-3xl p-12 text-center animate-fadeIn">
                            <div
                                class="w-24 h-24 bg-amber-50 rounded-full flex items-center justify-center mx-auto mb-6">
                                <i class="fa-solid fa-cart-shopping text-3xl text-amber-500"></i>
                            </div>
                            <h2 class="text-2xl font-bold text-zinc-900 mb-2">Your cart is empty</h2>
                            <p class="text-zinc-500 mb-8 max-w-sm mx-auto">Looks like you haven't added anything to your
                                cart yet. Discover our premium kitchenware collection.</p>
                            <a href="/all-utensils"
                                class="inline-flex items-center justify-center px-8 py-3.5 bg-zinc-900 text-white font-bold rounded-xl hover:bg-zinc-800 transition shadow-lg shadow-zinc-200">
                                Start Shopping
                            </a>
                        </div>
                        <% } else { %>

                            <!-- Table Header -->
                            <div
                                class="hidden md:grid grid-cols-6 gap-4 px-6 py-4 bg-amber-600 rounded-t-2xl text-xs font-bold uppercase tracking-widest text-white mb-1">
                                <div class="col-span-3">Product Description</div>
                                <div class="text-center">Price</div>
                                <div class="text-center">Quantity</div>
                                <div class="text-right">Subtotal</div>
                            </div>

                            <!-- Items List -->
                            <div class="space-y-4">
                                <% cart.forEach(item=> { %>
                                    <div class="bg-white border border-zinc-200 rounded-md p-4 md:p-6 cart-item-card ">
                                        <div class="grid grid-cols-1 md:grid-cols-6 gap-6 items-center">

                                            <!-- Product Info -->
                                            <div class="md:col-span-3 flex items-center gap-4">
                                                <div class="relative group">
                                                    <img src="<%= item.image_url %>" alt="<%= item.name %>"
                                                        class="h-20 w-20 object-cover rounded-xl border border-zinc-100">
                                                    <form action="/cart/remove" method="POST"
                                                        class="absolute -top-2 -left-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                                        <input type="hidden" name="id" value="<%= item.id %>">
                                                        <button type="submit"
                                                            class="w-6 h-6 bg-red-500 text-white rounded-full flex items-center justify-center text-[10px] hover:bg-red-600 transition shadow-lg">
                                                            <i class="fa-solid fa-xmark"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                                <div>
                                                    <h3 class="font-bold text-zinc-900 text-lg">
                                                        <%= item.name %>
                                                    </h3>
                                                    <p class="text-xs text-zinc-400 uppercase tracking-widest mt-1">
                                                        Premium Collection</p>
                                                </div>
                                            </div>

                                            <!-- Price -->
                                            <div class="text-center">
                                                <span
                                                    class="md:hidden text-xs text-zinc-400 uppercase mr-2">Price:</span>
                                                <span class="font-medium text-zinc-700">KES <%=
                                                        item.price.toLocaleString() %></span>
                                            </div>

                                            <!-- Quantity Controller -->
                                            <div class="flex justify-center items-center">
                                                <div
                                                    class="flex items-center bg-zinc-50 border border-zinc-200 rounded-xl p-1 px-2">
                                                    <form action="/cart/decrease" method="POST">
                                                        <input type="hidden" name="id" value="<%= item.id %>">
                                                        <button type="submit"
                                                            class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white hover:text-amber-600 transition active:scale-95">
                                                            <i class="fa-solid fa-minus text-[10px]"></i>
                                                        </button>
                                                    </form>
                                                    <span class="w-10 text-center font-bold text-zinc-800 text-sm">
                                                        <%= item.quantity %>
                                                    </span>
                                                    <form action="/cart/increase" method="POST">
                                                        <input type="hidden" name="id" value="<%= item.id %>">
                                                        <button type="submit"
                                                            class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white hover:text-amber-600 transition active:scale-95">
                                                            <i class="fa-solid fa-plus text-[10px]"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>

                                            <!-- Subtotal -->
                                            <div class="text-right">
                                                <span
                                                    class="md:hidden text-xs text-zinc-400 uppercase mr-2">Subtotal:</span>
                                                <span class="font-bold text-lg text-zinc-900">KES <%= (item.price *
                                                        item.quantity).toLocaleString() %></span>
                                            </div>

                                        </div>
                                    </div>
                                    <% }) %>
                            </div>

                            <!-- Cart Actions -->
                            <div class="mt-8 flex flex-wrap justify-between items-center gap-4">
                                <a href="/all-utensils"
                                    class="text-amber-600 font-semibold flex items-center gap-2 hover:translate-x-[-4px] transition-transform">
                                    <i class="fa-solid fa-arrow-left text-xs"></i>
                                    Back to Shopping
                                </a>
                                <form action="/cart/clear" method="POST">
                                    <button type="submit"
                                        class="text-zinc-400 hover:text-red-500 font-medium text-sm flex items-center gap-2 transition">
                                        <i class="fa-regular fa-trash-can"></i>
                                        Clear Entire Cart
                                    </button>
                                </form>
                            </div>

                            <% } %>

                </div>

                <!-- SUMMARY SECTION -->
                <% if (cart.length> 0) { %>
                    <div class="lg:w-1/3">
                        <div
                            class="bg-white border border-zinc-200 rounded-3xl p-8 sticky top-12 shadow-xl shadow-zinc-100">

                            <h2 class="text-2xl font-bold text-zinc-900 mb-8">Order Summary</h2>

                            <div class="space-y-4 mb-8">
                                <div class="flex justify-between text-zinc-500">
                                    <span>Cart Subtotal</span>
                                    <span class="font-medium text-zinc-900">KES <%= total.toLocaleString() %></span>
                                </div>
                                <div class="flex justify-between text-zinc-500">
                                    <span>Shipping estimate</span>
                                    <span class="font-medium text-zinc-900">KES <%= delivery.toLocaleString() %></span>
                                </div>
                                <div class="border-t border-zinc-100 pt-4 flex justify-between">
                                    <span class="text-zinc-900 font-bold text-lg">Order Total</span>
                                    <span class="text-amber-600 font-bold text-2xl tracking-tight">KES <%=
                                            grandTotal.toLocaleString() %></span>
                                </div>
                            </div>

                            <!-- Checkout Button -->
                            <button
                                class="w-full bg-zinc-900 hover:bg-zinc-800 text-white py-4 rounded-2xl font-bold tracking-wide shadow-lg shadow-zinc-200 transition-all duration-200 active:scale-[0.98] mb-6">
                                Proceed to Checkout
                            </button>

                            <!-- Trust Badges -->
                            <div class="grid grid-cols-2 gap-4 pt-6 border-t border-zinc-100">
                                <div class="text-center">
                                    <i class="fa-solid fa-lock text-zinc-400 text-xs mb-1"></i>
                                    <p class="text-[10px] text-zinc-400 uppercase tracking-widest font-bold">Secure
                                        Checkout</p>
                                </div>
                                <div class="text-center">
                                    <i class="fa-solid fa-rotate-left text-zinc-400 text-xs mb-1"></i>
                                    <p class="text-[10px] text-zinc-400 uppercase tracking-widest font-bold">Easy
                                        Returns</p>
                                </div>
                            </div>

                        </div>
                    </div>
                    <% } %>

            </div>

        </main>

        <%- include("../partials/toastr") %>
            <%- include("../partials/footer") %>
</body>

</html>