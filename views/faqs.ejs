<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/output.css">
    <link rel="shortcut icon" href="/images/Untitled_design-removebg-preview.png" type="image/x-icon">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <title>FAQs | Kitchenware</title>
</head>


<body class="bg-gradient-to-br from-zinc-50 to-zinc-100 text-zinc-800">


    <%- include("../partials/header.ejs") %>



        <section class="py-14">


            <div class="max-w-6xl mx-auto px-5">



                <!-- HEADER -->

                <div class="text-center max-w-3xl mx-auto">


                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full
bg-amber-100 text-amber-700 text-sm font-semibold">

                        <i class="fa-solid fa-circle-question"></i>

                        Customer Support

                    </span>



                    <h1 class="text-4xl md:text-5xl font-bold mt-6 text-zinc-900">
                        Frequently Asked Questions
                    </h1>
                    <p class="mt-4 text-zinc-500 text-lg">
                        Everything you need to know about ordering, payments,
                        delivery and our kitchenware products.
                    </p>
                    <!-- SEARCH -->
                    <div class="mt-8 relative">
                        <i class="fa-solid fa-search absolute left-5 top-4 text-zinc-400"></i>
                        <input id="faqSearch" type="text" placeholder="Search your question..." class="w-full pl-12 pr-5 py-4 rounded-2xl border bg-white shadow-sm focus:ring-4 focus:ring-amber-100 focus:border-amber-400 outline-none">
                    </div>
                </div>
                <!-- QUICK HELP CARDS -->
                <div class="grid md:grid-cols-4 gap-5 mt-12">
                    <div class="bg-white rounded-2xl p-5 border shadow-sm">
                        <i class="fa-solid fa-cart-shopping text-amber-500 text-2xl"></i>
                        <h3 class="font-bold mt-3">
                            Orders
                        </h3>
                        <p class="text-sm text-zinc-500 mt-1">
                            Order tracking and checkout help
                        </p>
                    </div>
                    <div class="bg-white rounded-2xl p-5 border shadow-sm">
                        <i class="fa-solid fa-money-bill-wave text-amber-500 text-2xl"></i>
                        <h3 class="font-bold mt-3">
                            Payments
                        </h3>
                        <p class="text-sm text-zinc-500 mt-1">
                            M-Pesa and payment questions
                        </p>
                    </div>
                    <div class="bg-white rounded-2xl p-5 border shadow-sm">
                        <i class="fa-solid fa-truck-fast text-amber-500 text-2xl"></i>
                        <h3 class="font-bold mt-3">
                            Delivery
                        </h3>
                        <p class="text-sm text-zinc-500 mt-1">
                            Shipping information
                        </p>
                    </div>
                    <div class="bg-white rounded-2xl p-5 border shadow-sm">
                        <i class="fa-solid fa-box-open text-amber-500 text-2xl"></i>
                        <h3 class="font-bold mt-3">
                            Products
                        </h3>
                        <p class="text-sm text-zinc-500 mt-1">
                            Product information
                        </p>
                    </div>
                </div>
                <!-- FAQ -->
                <div class="mt-14 space-y-4" id="faqContainer">
                    <div class="faq bg-white border rounded-2xl p-6 cursor-pointer">
                        <div class="flex justify-between items-center">
                            <h2 class="font-semibold text-lg">
                                How can I place an order?
                            </h2>
                            <i class="fa-solid fa-plus text-amber-500"></i>
                        </div>
                        <p class="answer hidden text-zinc-500 mt-4">
                            Simply browse products, add items to your cart,
                            checkout and complete payment.
                        </p>
                    </div>
                    <div class="faq bg-white border rounded-2xl p-6 cursor-pointer">
                        <div class="flex justify-between items-center">
                            <h2 class="font-semibold text-lg">
                                Do you accept M-Pesa payments?
                            </h2>
                            <i class="fa-solid fa-plus text-amber-500"></i>
                        </div>
                        <p class="answer hidden text-zinc-500 mt-4">
                            Yes. We support secure M-Pesa payments during checkout.
                        </p>
                    </div>
                    <div class="faq bg-white border rounded-2xl p-6 cursor-pointer">
                        <div class="flex justify-between items-center">
                            <h2 class="font-semibold text-lg">
                                How long does delivery take?
                            </h2>
                            <i class="fa-solid fa-plus text-amber-500"></i>
                        </div>
                        <p class="answer hidden text-zinc-500 mt-4">
                            Delivery depends on your location.
                            Most orders are processed quickly after payment confirmation.
                        </p>
                    </div>
                    <div class="faq bg-white border rounded-2xl p-6 cursor-pointer">
                        <div class="flex justify-between items-center">
                            <h2 class="font-semibold text-lg">
                                Can I return damaged items?
                            </h2>
                            <i class="fa-solid fa-plus text-amber-500"></i>
                        </div>
                        <p class="answer hidden text-zinc-500 mt-4">
                            Yes. Contact support if your product arrives damaged
                            or different from what you ordered.
                        </p>
                    </div>
                    <div class="faq bg-white border rounded-2xl p-6 cursor-pointer">
                        <div class="flex justify-between items-center">
                            <h2 class="font-semibold text-lg">
                                Are your kitchen products original?
                            </h2>
                            <i class="fa-solid fa-plus text-amber-500"></i>
                        </div>
                        <p class="answer hidden text-zinc-500 mt-4">
                            We provide quality kitchenware products from trusted suppliers.
                        </p>
                    </div>
                </div>
                <!-- CTA -->
                <div class="mt-14 rounded-3xl bg-gradient-to-r 
from-amber-500 to-amber-600 p-10 text-white">
                    <div class="flex flex-col md:flex-row
justify-between items-center gap-6">
                        <div>
                            <h2 class="text-3xl font-bold">
                                Need more help?
                            </h2>
                            <p class="text-amber-100 mt-2">
                                Our support team is ready to assist you.
                            </p>
                        </div>
                        <a href="/contact" class="bg-white text-amber-600
px-7 py-3 rounded-xl font-semibold
hover:bg-amber-50 transition">
                            Contact Support
                        </a>
                    </div>
                </div>
            </div>
        </section>
        <script>
            const items = document.querySelectorAll(".faq");
            items.forEach(item => {
                item.addEventListener("click", () => {
                    const answer = item.querySelector(".answer");
                    const icon = item.querySelector("i");
                    answer.classList.toggle("hidden");
                    icon.classList.toggle("fa-plus");
                    icon.classList.toggle("fa-minus");
                });
            });
            // search
            const search = document.getElementById("faqSearch");
            search.addEventListener("input", () => {
                let value = search.value.toLowerCase();
                document.querySelectorAll(".faq").forEach(item => {
                    let text = item.innerText.toLowerCase();
                    item.style.display = text.includes(value)
                        ? "block"
                        : "none";
                });
            });
        </script>
</body>

</html>