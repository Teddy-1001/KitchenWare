            <script>
                const year = document.getElementById('year');
                if (year) {
                    year.textContent = new Date().getFullYear();
                }
                const dealEndDate = new Date("2026-10-10T23:59:59").getTime();
                const wrapper = document.querySelector('.deal-timer');

                function updateDealTimer() {
                    const distance = dealEndDate - Date.now();

                    if (distance < 0) {
                        if (wrapper) {
                            wrapper.innerHTML = '<div class="text-center py-4"><p class="text-sm font-semibold text-red-500">Deal expired</p></div>';
                        }
                        return false;
                    }

                    const daysEl = document.getElementById('days');
                    const hoursEl = document.getElementById('hours');
                    const minutesEl = document.getElementById('minutes');
                    const secondsEl = document.getElementById('seconds');

                    if (!daysEl || !hoursEl || !minutesEl || !secondsEl) return false;

                    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                    daysEl.textContent = String(days).padStart(2, '0');
                    hoursEl.textContent = String(hours).padStart(2, '0');
                    minutesEl.textContent = String(minutes).padStart(2, '0');
                    secondsEl.textContent = String(seconds).padStart(2, '0');
                    return true;
                }

                if (updateDealTimer()) {
                    const timer = setInterval(() => {
                        if (!updateDealTimer()) clearInterval(timer);
                    }, 1000);
                }

            </script>
