<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700&display=swap"
        rel="stylesheet">
    <title>KitchenWare | Order #<%= order.id %></title>
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Outfit', sans-serif; }
    </style>
</head>

<body class="bg-zinc-50 antialiased">

    <%- include("../partials/header.ejs") %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <div class="mb-8">
            <a href="<%= typeof user !== 'undefined' && user ? '/orders' : '/orders/track' %>"
                class="text-amber-600 font-semibold flex items-center gap-2 hover:translate-x-[-4px] transition-transform mb-4">
                <i class="fa-solid fa-arrow-left text-xs"></i>
                Back to orders
            </a>
            <h1 class="text-4xl font-bold text-zinc-900 tracking-tight">Order #<%= order.id %></h1>
            <p class="text-zinc-500 mt-2 font-light">
                Placed on <%= new Date(order.created_at).toLocaleDateString('en-KE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
            </p>
        </div>

        <% if (message) { %>
            <div class="mb-6 flex items-center gap-3 p-4 <%= order.status === 'cancelled' ? 'bg-green-50 border-green-200 text-green-700' : 'bg-amber-50 border-amber-200 text-amber-800' %> border rounded-2xl">
                <i class="fa-solid fa-circle-info"></i>
                <p class="text-sm font-medium"><%= message %></p>
            </div>
        <% } %>

        <div class="flex flex-col lg:flex-row gap-8">

            <div class="lg:w-2/3 space-y-6">

                <!-- Tracking timeline -->
                <div class="bg-white border border-zinc-200 rounded-3xl p-6 md:p-8">
                    <h2 class="text-xl font-bold text-zinc-900 mb-6">Order Status</h2>

                    <% 
                    const steps = [
                        { key: 'placed', label: 'Order Placed', icon: 'fa-clipboard-check' },
                        { key: 'paid', label: 'Payment Confirmed', icon: 'fa-circle-check' },
                        { key: 'processing', label: 'Processing', icon: 'fa-box' },
                        { key: 'shipped', label: 'Shipped', icon: 'fa-truck' },
                        { key: 'delivered', label: 'Delivered', icon: 'fa-house-circle-check' }
                    ];
                    const statusOrder = ['pending', 'paid', 'processing', 'shipped', 'delivered'];
                    let currentIdx = statusOrder.indexOf(order.status);
                    if (order.status === 'pending' && order.payment_status === 'paid') currentIdx = 1;
                    if (order.status === 'cancelled') currentIdx = -1;
                    %>

                    <% if (order.status === 'cancelled') { %>
                        <div class="flex items-center gap-4 p-4 bg-red-50 border border-red-100 rounded-2xl">
                            <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center shrink-0">
                                <i class="fa-solid fa-ban text-red-500"></i>
                            </div>
                            <div>
                                <p class="font-bold text-red-700">Order Cancelled</p>
                                <p class="text-sm text-red-600/80">This order was cancelled and will not be delivered.</p>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="space-y-0">
                            <% steps.forEach((step, i) => {
                                const done = i <= currentIdx;
                                const active = i === currentIdx;
                            %>
                                <div class="flex gap-4">
                                    <div class="flex flex-col items-center">
                                        <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 border-2 <%= done ? 'bg-amber-500 border-amber-500 text-white' : 'bg-zinc-50 border-zinc-200 text-zinc-300' %>">
                                            <i class="fa-solid <%= step.icon %> text-sm"></i>
                                        </div>
                                        <% if (i < steps.length - 1) { %>
                                            <div class="w-0.5 flex-1 min-h-[2rem] my-1 <%= i < currentIdx ? 'bg-amber-400' : 'bg-zinc-200' %>"></div>
                                        <% } %>
                                    </div>
                                    <div class="pb-8 <%= i === steps.length - 1 ? 'pb-0' : '' %>">
                                        <p class="font-semibold <%= done ? 'text-zinc-900' : 'text-zinc-400' %>"><%= step.label %></p>
                                        <% if (active) { %>
                                            <p class="text-xs text-amber-600 font-medium mt-0.5">Current step</p>
                                        <% } %>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>

                <!-- Items -->
                <div class="space-y-4">
                    <% items.forEach(item => { %>
                        <div class="bg-white border border-zinc-200 rounded-xl p-4 md:p-6">
                            <div class="flex items-center gap-4">
                                <img src="<%= item.image_url %>" alt="<%= item.name %>"
                                    class="h-16 w-16 object-cover rounded-xl border border-zinc-100 shrink-0">
                                <div class="flex-1 min-w-0">
                                    <h3 class="font-bold text-zinc-900"><%= item.name %></h3>
                                    <p class="text-sm text-zinc-400">Qty: <%= item.quantity %></p>
                                </div>
                                <span class="font-bold text-zinc-900">KES <%= (Number(item.price) * item.quantity).toLocaleString() %></span>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Summary sidebar -->
            <div class="lg:w-1/3">
                <div class="bg-white border border-zinc-200 rounded-3xl p-8 sticky top-12 shadow-xl shadow-zinc-100">

                    <h2 class="text-xl font-bold text-zinc-900 mb-6">Order Summary</h2>

                    <div class="space-y-3 mb-6 text-sm">
                        <div class="flex justify-between text-zinc-500">
                            <span>Subtotal</span>
                            <span class="font-medium text-zinc-900">KES <%= Number(order.subtotal).toLocaleString() %></span>
                        </div>
                        <div class="flex justify-between text-zinc-500">
                            <span>Delivery (5%)</span>
                            <span class="font-medium text-zinc-900">KES <%= Number(order.shipping_fee).toLocaleString() %></span>
                        </div>
                        <div class="border-t border-zinc-100 pt-3 flex justify-between">
                            <span class="font-bold text-zinc-900">Total</span>
                            <span class="font-bold text-amber-600 text-xl">KES <%= Number(order.total).toLocaleString() %></span>
                        </div>
                    </div>

                    <div class="space-y-3 mb-6 pt-6 border-t border-zinc-100 text-sm">
                        <div>
                            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-1">Delivery Address</p>
                            <p class="text-zinc-700"><%= order.delivery_address || '—' %></p>
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-1">Phone</p>
                            <p class="text-zinc-700"><%= order.phone || '—' %></p>
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-1">Payment</p>
                            <p class="text-zinc-700 capitalize"><%= order.payment_method || '—' %>
                                <span class="text-zinc-400">·</span>
                                <%= order.payment_status %>
                            </p>
                        </div>
                        <% if (order.transaction_ref) { %>
                            <div>
                                <p class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-1">M-Pesa Receipt</p>
                                <p class="text-zinc-700 font-mono text-xs"><%= order.transaction_ref %></p>
                            </div>
                        <% } %>
                        <% if (order.refund_status) { %>
                            <div>
                                <p class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-1">Refund Status</p>
                                <p class="text-zinc-700 capitalize">
                                    <%= order.refund_status %>
                                    <% if (order.refund_transaction_id) { %>
                                        <span class="block font-mono text-xs text-zinc-500 mt-0.5"><%= order.refund_transaction_id %></span>
                                    <% } %>
                                </p>
                            </div>
                        <% } %>
                    </div>

                    <% if (canCancel) { %>
                        <form action="/orders/<%= order.id %>/cancel" method="POST"
                            onsubmit="return confirm('Cancel this order? If you paid via M-Pesa, a refund will be sent to your phone.');">
                            <button type="submit"
                                class="w-full border border-red-200 text-red-600 hover:bg-red-50 py-3.5 rounded-2xl font-bold transition mb-4">
                                <i class="fa-solid fa-ban mr-2"></i>Cancel Order
                            </button>
                        </form>
                        <p class="text-xs text-zinc-400 text-center">You can cancel before the order is shipped.</p>
                    <% } else if (order.status !== 'cancelled') { %>
                        <p class="text-xs text-zinc-400 text-center py-2">This order can no longer be cancelled.</p>
                    <% } %>

                </div>
            </div>

        </div>
    </main>

    <%- include("../partials/toastr") %>
    <%- include("../partials/footer") %>
</body>

</html>
