<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700&display=swap"
        rel="stylesheet">

    <title>KitchenWare | Order Confirmed</title>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        h1,
        h2,
        h3,
        h4 {
            font-family: 'Outfit', sans-serif;
        }

        @keyframes successPop {
            0% { transform: scale(0.5); opacity: 0; }
            70% { transform: scale(1.08); }
            100% { transform: scale(1); opacity: 1; }
        }

        .success-icon {
            animation: successPop 0.5s ease-out forwards;
        }
    </style>
</head>

<body class="bg-zinc-50 antialiased">

    <%- include("../partials/header.ejs") %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Success Banner -->
        <div class="text-center mb-12">
            <div class="success-icon w-24 h-24 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-6 border border-green-100">
                <i class="fa-solid fa-check text-4xl text-green-500"></i>
            </div>
            <h1 class="text-4xl font-bold text-zinc-900 tracking-tight">Order Placed Successfully</h1>
            <p class="text-zinc-500 mt-2 font-light max-w-lg mx-auto">
                Thank you for your purchase. We've received your order and will begin processing it shortly.
            </p>
            <p class="mt-4 inline-flex items-center gap-2 px-4 py-2 bg-white border border-zinc-200 rounded-full text-sm font-semibold text-zinc-700">
                <i class="fa-solid fa-receipt text-amber-500"></i>
                Order #<%= order.id %>
            </p>
        </div>

        <div class="flex flex-col lg:flex-row gap-8">

            <!-- ORDER ITEMS -->
            <div class="lg:w-2/3">

                <div class="hidden md:grid grid-cols-6 gap-4 px-6 py-4 bg-amber-600 rounded-t-2xl text-xs font-bold uppercase tracking-widest text-white mb-1">
                    <div class="col-span-3">Product</div>
                    <div class="text-center">Price</div>
                    <div class="text-center">Quantity</div>
                    <div class="text-right">Subtotal</div>
                </div>

                <div class="space-y-4">
                    <% items.forEach(item => { %>
                        <div class="bg-white border border-zinc-200 rounded-md p-4 md:p-6">
                            <div class="grid grid-cols-1 md:grid-cols-6 gap-6 items-center">

                                <div class="md:col-span-3 flex items-center gap-4">
                                    <img src="<%= item.image_url %>" alt="<%= item.name %>"
                                        class="h-20 w-20 object-cover rounded-xl border border-zinc-100">
                                    <div>
                                        <h3 class="font-bold text-zinc-900 text-lg"><%= item.name %></h3>
                                        <p class="text-xs text-zinc-400 uppercase tracking-widest mt-1">Premium Collection</p>
                                    </div>
                                </div>

                                <div class="text-center">
                                    <span class="md:hidden text-xs text-zinc-400 uppercase mr-2">Price:</span>
                                    <span class="font-medium text-zinc-700">KES <%= Number(item.price).toLocaleString() %></span>
                                </div>

                                <div class="text-center">
                                    <span class="md:hidden text-xs text-zinc-400 uppercase mr-2">Qty:</span>
                                    <span class="font-bold text-zinc-800"><%= item.quantity %></span>
                                </div>

                                <div class="text-right">
                                    <span class="md:hidden text-xs text-zinc-400 uppercase mr-2">Subtotal:</span>
                                    <span class="font-bold text-lg text-zinc-900">KES <%= (Number(item.price) * item.quantity).toLocaleString() %></span>
                                </div>

                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Delivery Info -->
                <div class="mt-8 bg-white border border-zinc-200 rounded-3xl p-6 md:p-8">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center">
                            <i class="fa-solid fa-truck text-amber-600"></i>
                        </div>
                        <div>
                            <h2 class="text-xl font-bold text-zinc-900">Delivery Details</h2>
                            <p class="text-sm text-zinc-400">Where your order is headed</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                        <div>
                            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-1">Address</p>
                            <p class="text-zinc-700 font-medium"><%= order.delivery_address || '—' %></p>
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-1">Phone</p>
                            <p class="text-zinc-700 font-medium"><%= order.phone || '—' %></p>
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-1">Payment Method</p>
                            <p class="text-zinc-700 font-medium capitalize"><%= order.payment_method || '—' %></p>
                        </div>
                        <div>
                            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-1">Status</p>
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-green-50 text-green-700 text-xs font-bold uppercase tracking-wider rounded-full border border-green-100">
                                <i class="fa-solid fa-circle text-[6px]"></i>
                                <%= order.payment_status  || 'pending' %>
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ORDER SUMMARY -->
            <div class="lg:w-1/3">
                <div class="bg-white border border-zinc-200 rounded-3xl p-8 sticky top-12 shadow-xl shadow-zinc-100">

                    <h2 class="text-2xl font-bold text-zinc-900 mb-8">Order Summary</h2>

                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between text-zinc-500">
                            <span>Subtotal</span>
                            <span class="font-medium text-zinc-900">KES <%= Number(order.subtotal).toLocaleString() %></span>
                        </div>
                        <div class="flex justify-between text-zinc-500">
                            <span>Delivery (5%)</span>
                            <span class="font-medium text-zinc-900">KES <%= Number(order.shipping_fee).toLocaleString() %></span>
                        </div>
                        <div class="border-t border-zinc-100 pt-4 flex justify-between">
                            <span class="text-zinc-900 font-bold text-lg">Order Total</span>
                            <span class="text-amber-600 font-bold text-2xl tracking-tight">KES <%= Number(order.total).toLocaleString() %></span>
                        </div>
                    </div>

                    <a href="/orders/<%= order.id %>"
                        class="w-full inline-flex items-center justify-center bg-amber-600 hover:bg-amber-700 text-white py-4 rounded-2xl font-bold tracking-wide shadow-lg shadow-amber-200 transition-all duration-200 active:scale-[0.98] mb-4">
                        <i class="fa-solid fa-truck-fast mr-2"></i>
                        Track This Order
                    </a>

                    <a href="/all-utensils"
                        class="w-full inline-flex items-center justify-center bg-zinc-900 hover:bg-zinc-800 text-white py-4 rounded-2xl font-bold tracking-wide shadow-lg shadow-zinc-200 transition-all duration-200 active:scale-[0.98] mb-6">
                        Continue Shopping
                    </a>

                    <a href="/"
                        class="w-full inline-flex items-center justify-center text-amber-600 font-semibold gap-2 hover:translate-x-[-4px] transition-transform mb-6">
                        <i class="fa-solid fa-house text-xs"></i>
                        Back to Home
                    </a>

                    <!-- Trust Badges -->
                    <div class="grid grid-cols-2 gap-4 pt-6 border-t border-zinc-100">
                        <div class="text-center">
                            <i class="fa-solid fa-envelope text-zinc-400 text-xs mb-1"></i>
                            <p class="text-[10px] text-zinc-400 uppercase tracking-widest font-bold">Confirmation Sent</p>
                        </div>
                        <div class="text-center">
                            <i class="fa-solid fa-headset text-zinc-400 text-xs mb-1"></i>
                            <p class="text-[10px] text-zinc-400 uppercase tracking-widest font-bold">Support Available</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </main>

    <%- include("../partials/toastr") %>
    <%- include("../partials/footer") %>
</body>

</html>
