<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700&display=swap"
        rel="stylesheet">

    <title>KitchenWare | Create Account</title>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        h1,
        h2,
        h3 {
            font-family: 'Outfit', sans-serif;
        }

        .auth-gradient {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        }

        .input-focus-effect:focus {
            box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.15);
        }
    </style>
</head>

<body class="bg-zinc-50 antialiased">

    <div class="flex min-h-screen">

        <!-- LEFT SIDE: Brand & Aesthetic -->
        <div class="hidden lg:flex w-1/2 auth-gradient relative overflow-hidden items-center justify-center">

            <!-- Abstract Decorative Elements -->
            <div class="absolute w-[500px] h-[500px] bg-white/10 rounded-full blur-[100px] -top-40 -left-40"></div>
            <div class="absolute w-[400px] h-[400px] bg-black/5 rounded-full blur-[80px] bottom-0 right-0"></div>

            <div class="relative z-10 flex flex-col items-center p-12 text-white w-full max-w-xl">

                <!-- Logo -->
                <div class="mb-12">
                    <img src="/images/Untitled_design-removebg-preview.png" alt="Logo"
                        class="w-24 h-24 object-contain drop-shadow-2xl">
                </div>

                <!-- Content -->
                <div class="text-center">
                    <h1 class="text-6xl font-bold leading-tight tracking-tight">
                        Start Your <br> <span class="text-zinc-900/90">Masterclass Journey</span>
                    </h1>

                    <p class="text-lg text-white/90 mt-6 font-light leading-relaxed">
                        Join our community of kitchen enthusiasts and unlock exclusive access to premium tools and
                        deals.
                    </p>

                    <div class="grid grid-cols-3 gap-8 mt-12 text-center">
                        <div>
                            <h3 class="font-bold text-3xl">5K+</h3>
                            <p class="text-xs text-white/70 uppercase tracking-widest mt-1">Products</p>
                        </div>
                        <div>
                            <h3 class="font-bold text-3xl">10K+</h3>
                            <p class="text-xs text-white/70 uppercase tracking-widest mt-1">Cooks</p>
                        </div>
                        <div>
                            <h3 class="font-bold text-3xl">24/7</h3>
                            <p class="text-xs text-white/70 uppercase tracking-widest mt-1">Support</p>
                        </div>
                    </div>
                </div>

                <!-- Bottom indicators -->
                <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex gap-2">
                    <div class="w-2 h-1.5 bg-white/40 rounded-full"></div>
                    <div class="w-8 h-1.5 bg-white rounded-full"></div>
                    <div class="w-2 h-1.5 bg-white/40 rounded-full"></div>
                </div>

            </div>
        </div>

        <!-- RIGHT SIDE: Register Form -->
        <div class="w-full lg:w-1/2 flex items-center justify-center p-8 md:p-12">

            <div class="w-full max-w-md">

                <!-- Mobile Logo -->
                <div class="lg:hidden flex justify-center mb-8">
                    <img src="/images/Untitled_design-removebg-preview.png" alt="Logo" class="h-16 w-auto">
                </div>

                <!-- Header -->
                <div class="mb-8">
                    <h2 class="text-4xl font-bold text-zinc-900 tracking-tight">
                        Create Account
                    </h2>
                    <p class="text-zinc-500 mt-2 font-light">
                        Join KitchenWare today and start cooking like a pro.
                    </p>
                </div>

                <!-- Social Login Section -->
                <div class="grid grid-cols-3 gap-3 mb-8">
                    <button
                        class="flex items-center justify-center py-3 border border-zinc-200 rounded-xl hover:bg-zinc-50 transition-all duration-200 group">
                        <i class="fa-brands fa-google text-red-500 group-hover:scale-110 transition-transform"></i>
                    </button>
                    <button
                        class="flex items-center justify-center py-3 border border-zinc-200 rounded-xl hover:bg-zinc-50 transition-all duration-200 group">
                        <i class="fa-brands fa-apple text-zinc-900 group-hover:scale-110 transition-transform"></i>
                    </button>
                    <button
                        class="flex items-center justify-center py-3 border border-zinc-200 rounded-xl hover:bg-zinc-50 transition-all duration-200 group">
                        <i class="fa-brands fa-facebook text-blue-600 group-hover:scale-110 transition-transform"></i>
                    </button>
                </div>

                <div class="relative flex items-center mb-8">
                    <div class="flex-grow border-t border-zinc-200"></div>
                    <span
                        class="flex-shrink mx-4 text-zinc-400 text-xs uppercase tracking-widest font-semibold">Registration
                        Details</span>
                    <div class="flex-grow border-t border-zinc-200"></div>
                </div>

                <!-- Form -->
                <form action="/register" method="POST" class="space-y-4">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-2">
                            <label class="text-sm font-semibold text-zinc-700 ml-1">Full Name</label>
                            <input type="text" name="name" required
                                class="w-full px-4 py-3 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-amber-500 transition-all input-focus-effect"
                                placeholder="Teddy Webo">
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-semibold text-zinc-700 ml-1">Phone Number</label>
                            <input type="tel" name="phone" required
                                class="w-full px-4 py-3 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-amber-500 transition-all input-focus-effect"
                                placeholder="+254 700 000 000">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-zinc-700 ml-1">Email Address</label>
                        <input type="email" name="email" required
                            class="w-full px-4 py-3 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-amber-500 transition-all input-focus-effect"
                            placeholder="teddy@example.com">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-2">
                            <label class="text-sm font-semibold text-zinc-700 ml-1">Password</label>
                            <input type="password" name="password" required
                                class="w-full px-4 py-3 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-amber-500 transition-all input-focus-effect"
                                placeholder="••••••••">
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-semibold text-zinc-700 ml-1">Confirm</label>
                            <input type="password" name="confirm_password" required
                                class="w-full px-4 py-3 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-amber-500 transition-all input-focus-effect"
                                placeholder="••••••••">
                        </div>
                    </div>

                    <div class="pt-2">
                        <label class="flex items-start gap-3 cursor-pointer group">
                            <input type="checkbox" required
                                class="mt-1 w-4 h-4 text-amber-500 border-zinc-300 rounded focus:ring-amber-500 accent-amber-500">
                            <span class="text-sm text-zinc-600 select-none">
                                I agree to the <a href="#" class="text-amber-600 font-semibold hover:underline">Terms of
                                    Service</a> and <a href="#"
                                    class="text-amber-600 font-semibold hover:underline">Privacy Policy</a>
                            </span>
                        </label>
                    </div>

                    <button type="submit"
                        class="w-full bg-zinc-900 hover:bg-zinc-800 active:scale-[0.98] text-white py-4 rounded-xl font-bold tracking-wide transition-all duration-200 mt-4">
                        Create Account
                    </button>

                </form>

                <!-- Footer -->
                <p class="text-center text-zinc-500 mt-8 font-light">
                    Already a member?
                    <a href="/login" class="text-amber-600 font-bold hover:text-amber-700 transition">
                        Sign In
                    </a>
                </p>

            </div>

        </div>

    </div>

    <!-- Include Toastr Partial -->
    <%- include('../partials/toastr') %>

</body>

</html>